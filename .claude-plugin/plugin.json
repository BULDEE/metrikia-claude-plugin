{
  "name": "metrikia",
  "description": "Metrikia MCP plugin — AI-powered ad tracking and ROI analysis for Media Buyers, Ad Agencies, and Entrepreneurs. Access campaigns, leads, attribution, and Diana AI insights directly from Claude.",
  "version": "1.1.0",
  "author": {
    "name": "Metrikia",
    "email": "support@metrikia.io"
  },
  "homepage": "https://metrikia.io/integrations/ai",
  "repository": "https://github.com/BULDEE/metrikia-claude-plugin",
  "license": "MIT",
  "keywords": ["ads", "media-buying", "roi", "attribution", "mcp", "metrikia", "performance-marketing"],
  "mcpServers": {
    "metrikia": {
      "type": "http",
      "url": "https://mcp.metrikia.io/api/v1/mcp",
      "headers": {
        "Authorization": "Bearer ${METRIKIA_API_KEY}"
      }
    }
  },
  "userConfig": {
    "default_period": {
      "type": "string",
      "title": "Default analysis period",
      "description": "7d, 30d, or 90d (default: 30d)",
      "sensitive": false
    },
    "language": {
      "type": "string",
      "title": "Report language",
      "description": "en or fr (default: en)",
      "sensitive": false
    }
  }
}
